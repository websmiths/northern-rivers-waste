---
import { SITE, PRIMARY_NAV, withBase } from '../site';
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/'
    ? pathname === withBase('/')
    : pathname.startsWith(withBase(href));
---

<header
  class="sticky top-0 z-40 border-b border-line-dark bg-[rgba(14,19,22,0.82)] backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-7 py-[15px]"
    aria-label="Primary"
  >
    <a
      href={withBase('/')}
      class="flex items-center gap-[11px] text-white no-underline"
    >
      <span
        class="h-[11px] w-[11px] rounded-[3px] bg-brand-bright shadow-[0_0_16px_var(--brand-bright)]"
        aria-hidden="true"></span>
      <span
        class="font-display text-base font-extrabold uppercase tracking-[0.02em]"
      >
        {SITE.name}
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-1 sm:flex">
      {
        PRIMARY_NAV.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'rounded-lg px-3.5 py-2 font-body text-[0.82rem] font-medium no-underline transition-colors',
                isActive(item.href)
                  ? 'bg-white/10 text-white'
                  : 'text-[#aeb8be] hover:bg-white/[0.08] hover:text-white',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile disclosure (no JS framework — native <details>) -->
    <details class="relative sm:hidden">
      <summary
        class="flex cursor-pointer list-none items-center gap-1.5 rounded-lg border border-line-dark px-3 py-1.5 font-body text-sm text-[#aeb8be]"
        aria-label="Open menu"
      >
        Menu
        <span aria-hidden="true" class="text-brand-bright">▾</span>
      </summary>
      <ul
        class="absolute right-0 mt-2 w-48 rounded-lg border border-line-dark bg-ink py-1 shadow-lg"
      >
        {
          PRIMARY_NAV.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class="block px-4 py-2 font-body text-[#aeb8be] no-underline hover:bg-white/[0.08] hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
  </nav>
</header>
