---
import { withBase } from '../site';
import ClaimScores from './ClaimScores.astro';
import type { Scorecard } from '../data/scorecard';
// One line-by-line item in a post breakdown: the quoted passage on the left,
// the response on the right (verdict pill + body slot + optional detail link).
interface Props {
  /** Two-digit ordinal, e.g. "01". */
  n: string;
  /** The verbatim passage being answered. */
  quote: string;
  /** Short verdict shown as a pill. */
  verdict: string;
  /** Colour key for the pill / accent. */
  tone?: 'spin' | 'fair' | 'unsupported';
  /** Optional link out to the page that does the detailed work. */
  link?: { href: string; label: string };
  /** Optional per-claim scorecard. */
  scores?: Scorecard;
}
const { n, quote, verdict, tone = 'spin', link, scores } = Astro.props;
---

<article class={`reb tone-${tone}`}>
  <div class="reb-quote">
    <span class="reb-n">{n}</span>
    <blockquote>&ldquo;{quote}&rdquo;</blockquote>
  </div>

  <div class="reb-resp">
    <span class="pill">{verdict}</span>
    <div class="reb-body">
      <slot />
    </div>
    {
      link && (
        <a class="reb-link" href={withBase(link.href)}>
          {link.label}
          <span class="arr" aria-hidden="true">
            &rarr;
          </span>
        </a>
      )
    }
    {scores && <ClaimScores scores={scores} />}
  </div>
</article>

<style>
  .reb {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 28px;
    padding: 28px 0;
    border-top: 1px solid var(--line);
    align-items: start;
  }
  .reb-quote {
    position: relative;
    padding-left: 18px;
    border-left: 3px solid var(--accent);
  }
  .tone-fair .reb-quote {
    border-left-color: var(--brand);
  }
  .tone-unsupported .reb-quote {
    border-left-color: var(--water);
  }
  .reb-n {
    display: block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .reb-quote blockquote {
    margin: 0;
    font-family: 'Archivo', sans-serif;
    font-weight: 600;
    font-size: 1.12rem;
    line-height: 1.34;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .pill {
    display: inline-block;
    padding: 4px 11px;
    border-radius: 999px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    background: rgba(255, 93, 62, 0.12);
    color: #b23a23;
  }
  .tone-fair .pill {
    background: rgba(12, 107, 96, 0.12);
    color: var(--brand);
  }
  .tone-unsupported .pill {
    background: rgba(31, 93, 110, 0.12);
    color: var(--water);
  }
  .reb-body {
    margin-top: 12px;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .reb-body :global(p + p) {
    margin-top: 0.8em;
  }
  .reb-body :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }
  .reb-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--brand);
    text-decoration: none;
  }
  .reb-link .arr {
    color: var(--accent);
    transition: transform 0.18s ease;
  }
  .reb-link:hover .arr {
    transform: translateX(4px);
  }

  @media (max-width: 760px) {
    .reb {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
