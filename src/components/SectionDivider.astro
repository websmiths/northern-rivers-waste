---
interface Props {
  /** Optional anchor id for in-page linking. */
  id?: string;
}
const { id } = Astro.props;
---

<div class="mt-12 scroll-mt-24" id={id}>
  <p class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-ochre-text">
    <slot />
  </p>
  <div class="mt-2 h-px w-full bg-rule"></div>
</div>
