---
// Chart 5 — HDPE geomembrane service life vs temperature. Illustrative curve;
// magnitudes follow the ranges in Rowe (2020): ~54 years at 60°C rising to
// several hundred years at lower temperatures. Typical operating range shaded.
const W = 720, H = 380;
const padL = 60, padR = 24, padT = 28, padB = 52;
const plotW = W - padL - padR;
const plotH = H - padT - padB;
const tMin = 20, tMax = 60;
const yMax = 650;
const x = (t: number) => padL + ((t - tMin) / (tMax - tMin)) * plotW;
const y = (v: number) => padT + plotH - (v / yMax) * plotH;
const pts: [number, number][] = [
  [20, 600], [25, 400], [30, 250], [35, 170], [40, 120], [45, 92], [50, 72], [55, 60], [60, 54],
];
const path = pts.map((p, i) => `${i === 0 ? 'M' : 'L'} ${x(p[0]).toFixed(1)} ${y(p[1]).toFixed(1)}`).join(' ');
const yTicks = [0, 100, 200, 300, 400, 500, 600];
const xTicks = [20, 30, 40, 50, 60];
---

<svg viewBox={`0 0 ${W} ${H}`} role="img" aria-labelledby="ll-title ll-desc">
  <title id="ll-title">Geomembrane liner service life versus temperature</title>
  <desc id="ll-desc">
    Line chart showing how high-density polyethylene liner service life falls
    steeply as temperature rises: from several hundred years at around 20 to
    30 degrees Celsius down to roughly 54 years at 60 degrees Celsius. The
    typical landfill liner operating range, about 30 to 40 degrees, is shaded.
    Magnitudes follow the ranges in Rowe (2020).
  </desc>

  <!-- shaded typical operating range 30–40°C -->
  <rect x={x(30)} y={padT} width={x(40) - x(30)} height={plotH} fill="var(--ochre)" opacity="0.1"></rect>
  <text x={(x(30) + x(40)) / 2} y={padT + 14} text-anchor="middle" font-size="10.5" font-family="'IBM Plex Mono', monospace" fill="var(--ochre)">typical range</text>

  {yTicks.map((v) => (
    <g>
      <line x1={padL} y1={y(v)} x2={W - padR} y2={y(v)} stroke="var(--rule)"></line>
      <text x={padL - 8} y={y(v) + 4} text-anchor="end" font-size="11" font-family="'IBM Plex Mono', monospace" fill="var(--ink)" opacity="0.6">{v}</text>
    </g>
  ))}
  {xTicks.map((t) => (
    <text x={x(t)} y={H - padB + 20} text-anchor="middle" font-size="11" font-family="'IBM Plex Mono', monospace" fill="var(--ink)" opacity="0.6">{t}°C</text>
  ))}

  <!-- axis titles -->
  <text x={padL - 44} y={padT + plotH / 2} transform={`rotate(-90 ${padL - 44} ${padT + plotH / 2})`} text-anchor="middle" font-size="11.5" font-family="'Inter', sans-serif" fill="var(--ink)" opacity="0.7">Service life (years)</text>
  <text x={padL + plotW / 2} y={H - 12} text-anchor="middle" font-size="11.5" font-family="'Inter', sans-serif" fill="var(--ink)" opacity="0.7">Liner temperature</text>

  <path d={path} fill="none" stroke="var(--water)" stroke-width="2.5"></path>

  <!-- highlight the 54yr @ 60°C anchor -->
  <circle cx={x(60)} cy={y(54)} r="4.5" fill="var(--alert)"></circle>
  <text x={x(60) - 8} y={y(54) - 8} text-anchor="end" font-size="12" font-weight="600" font-family="'IBM Plex Mono', monospace" fill="var(--alert)">~54 yr @ 60°C</text>
</svg>
