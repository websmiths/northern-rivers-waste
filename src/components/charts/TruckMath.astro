---
// Chart 2 — the truck math. Arithmetic decomposition, pure SVG, no JS.
// 60,000 t ÷ 250 operating days ÷ ~18 t/load ≈ 13 inbound loads/day.
// Plus outbound, leachate tankers, cover-soil, staff → ~30–50 movements/day.
const W = 720, H = 430;
// Stacked daily-movement breakdown (illustrative midpoint ≈ 40/day)
const segs = [
  { label: 'Inbound waste loads', value: 13, color: 'var(--ochre)' },
  { label: 'Outbound (empty return)', value: 13, color: 'var(--moss)' },
  { label: 'Cover-soil deliveries', value: 6, color: 'var(--water)' },
  { label: 'Leachate tankers', value: 4, color: 'var(--basalt)' },
  { label: 'Staff & service vehicles', value: 6, color: 'var(--rule)' },
];
const total = segs.reduce((a, s) => a + s.value, 0);
const barX = 40, barY = 250, barW = 640, barH = 46;
let acc = 0;
const placed = segs.map((s) => {
  const x = barX + (acc / total) * barW;
  const w = (s.value / total) * barW;
  acc += s.value;
  return { ...s, x, w };
});
---

<svg viewBox={`0 0 ${W} ${H}`} role="img" aria-labelledby="tm-title tm-desc">
  <title id="tm-title">How 60,000 tonnes a year decomposes into daily truck movements</title>
  <desc id="tm-desc">
    60,000 tonnes divided by about 250 operating days divided by about 18 tonnes
    per load is roughly 13 inbound loads per day. Adding empty return trips,
    cover-soil deliveries, leachate tankers and staff vehicles gives an
    illustrative total of about 40 vehicle movements per day at the gate — not
    400, and not zero.
  </desc>

  <!-- arithmetic row -->
  <g font-family="'IBM Plex Mono', monospace" fill="var(--basalt)">
    <text x="40" y="48" font-size="22" font-weight="500">60,000 t</text>
    <text x="170" y="48" font-size="22" fill="var(--ochre)">÷</text>
    <text x="196" y="48" font-size="22" font-weight="500">250 days</text>
    <text x="330" y="48" font-size="22" fill="var(--ochre)">÷</text>
    <text x="356" y="48" font-size="22" font-weight="500">~18 t/load</text>
    <text x="520" y="48" font-size="22" fill="var(--ochre)">≈</text>
    <text x="548" y="48" font-size="22" font-weight="600" fill="var(--ochre-text)">13 loads</text>
  </g>
  <g font-family="'Inter', sans-serif" fill="var(--ink)" opacity="0.7" font-size="12">
    <text x="40" y="68">per year</text>
    <text x="196" y="68">operating</text>
    <text x="356" y="68">avg payload</text>
    <text x="548" y="68">inbound / day</text>
  </g>

  <line x1="40" y1="92" x2="680" y2="92" stroke="var(--rule)"></line>

  <text x="40" y="128" font-family="'Inter', sans-serif" font-size="15" fill="var(--basalt)" font-weight="500">But the gate sees more than inbound loads:</text>

  <!-- stacked bar -->
  <text x={barX} y={barY - 14} font-family="'IBM Plex Mono', monospace" font-size="12" fill="var(--ink)" opacity="0.7">Illustrative daily vehicle movements at the gate</text>
  {placed.map((p) => (
    <rect x={p.x} y={barY} width={Math.max(p.w - 1.5, 1)} height={barH} fill={p.color}></rect>
  ))}
  <rect x={barX} y={barY} width={barW} height={barH} fill="none" stroke="var(--basalt)" stroke-width="1"></rect>
  <text x={barX + barW} y={barY - 14} text-anchor="end" font-family="'IBM Plex Mono', monospace" font-size="13" font-weight="600" fill="var(--ochre-text)">≈ {total} movements/day</text>

  <!-- legend -->
  <g font-family="'Inter', sans-serif" font-size="12.5" fill="var(--ink)">
    {placed.map((p, i) => {
      const col = i % 2;
      const row = Math.floor(i / 2);
      const lx = 40 + col * 340;
      const ly = barY + 86 + row * 24;
      return (
        <g>
          <rect x={lx} y={ly - 11} width="13" height="13" rx="2" fill={p.color} stroke="var(--basalt)" stroke-width="0.5"></rect>
          <text x={lx + 20} y={ly}>{p.label} — {p.value}/day</text>
        </g>
      );
    })}
  </g>
</svg>
