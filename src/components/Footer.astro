---
import { SITE, FOOTER_NAV, withBase } from '../site';
// Build-time "last updated" date surfaced in the footer (spec §11).
const lastUpdated = new Date().toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<footer class="mt-24 border-t border-line-dark bg-ink text-paper">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="grid gap-10 sm:grid-cols-[1fr_auto]">
      <div class="max-w-md">
        <p class="font-display text-2xl font-extrabold uppercase tracking-[0.02em] text-paper">{SITE.name}</p>
        <p class="mt-3 font-body text-[0.95rem] leading-relaxed text-paper/80">
          {SITE.tagline} An independent, evidence-based information resource —
          not a petition or campaign platform.
        </p>
        <p class="mt-4 font-mono text-xs text-paper/70">
          Corrections &amp; sources:
          <a href={`mailto:${SITE.contactEmail}`} class="text-brand-bright underline"
            >{SITE.contactEmail}</a
          >
        </p>
      </div>

      <nav aria-label="Site map">
        <p class="font-mono text-xs uppercase tracking-widest text-paper/60">
          Site map
        </p>
        <ul class="mt-3 space-y-1.5">
          {
            FOOTER_NAV.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  class="font-body text-[0.95rem] text-paper no-underline transition-colors hover:text-brand-bright"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-white/10 pt-6 font-mono text-xs text-paper/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>Last updated {lastUpdated}.</p>
      <p>
        Published under fair-comment principles. No personal data collected;
        no cookies.
      </p>
    </div>
  </div>
</footer>
