---
import { SCORE_AXES, type Scorecard } from '../data/scorecard';
// A compact per-claim scorecard: four axes, each a 3-step meter + rating word.
// Scores the claim and its language, never the author. See data/scorecard.ts.
interface Props {
  scores: Scorecard;
}
const { scores } = Astro.props;
---

<div class="sc" role="group" aria-label="Claim scorecard">
  <p class="sc-cap">Scorecard <span aria-hidden="true">&middot;</span> the claim, not the person</p>
  <div class="sc-axes">
    {
      SCORE_AXES.map((axis) => {
        const level = scores[axis.key];
        return (
          <div class="sc-axis" data-level={level} title={axis.blurb}>
            <span class="sc-meter" aria-hidden="true">
              <i></i>
              <i></i>
              <i></i>
            </span>
            <span class="sc-text">
              <b class="sc-label">{axis.label}</b>
              <b class="sc-val">{axis.levels[level]}</b>
            </span>
          </div>
        );
      })
    }
  </div>
</div>

<style>
  .sc {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px dashed var(--line);
  }
  .sc-cap {
    margin: 0 0 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .sc-axes {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }
  .sc-axis {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .sc-meter {
    display: flex;
    gap: 3px;
  }
  .sc-meter i {
    flex: 1;
    height: 4px;
    border-radius: 2px;
    background: var(--line);
  }
  /* fill segments by level */
  .sc-axis[data-level='poor'] .sc-meter i:nth-child(-n + 1) {
    background: var(--accent);
  }
  .sc-axis[data-level='mixed'] .sc-meter i:nth-child(-n + 2) {
    background: var(--amber);
  }
  .sc-axis[data-level='good'] .sc-meter i:nth-child(-n + 3) {
    background: var(--brand);
  }
  .sc-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .sc-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    font-weight: 500;
  }
  .sc-val {
    font-family: 'Archivo', sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-top: 3px;
  }
  .sc-axis[data-level='poor'] .sc-val {
    color: #b23a23;
  }
  .sc-axis[data-level='mixed'] .sc-val {
    color: var(--amber-ink);
  }
  .sc-axis[data-level='good'] .sc-val {
    color: var(--brand);
  }

  @media (max-width: 540px) {
    .sc-axes {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px 16px;
    }
  }
</style>
