---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Standfirst from '../components/Standfirst.astro';
import CardLink from '../components/CardLink.astro';
import PullQuote from '../components/PullQuote.astro';
import { SITE } from '../site';

const cards = [
  {
    href: '/proposal',
    index: '01',
    title: 'The proposal',
    summary:
      'A plain-language account of what Lismore City Council is actually investigating — site, scale, timeline and stated safeguards.',
  },
  {
    href: '/critique',
    index: '02',
    title: 'The critique',
    summary:
      'What is accurate, what is spin, what is misleading by implication, and the major questions the public case has left out.',
  },
  {
    href: '/alternatives',
    index: '03',
    title: 'Alternatives',
    summary:
      'Three credible approaches the public debate has barely canvassed — built around existing licensed facilities, not a new greenfield hole.',
  },
  {
    href: '/numbers',
    index: '04',
    title: 'The numbers',
    summary:
      'Tonnage, truck movements, 50-year cumulative deposit, the waste hierarchy, and what liner service life actually depends on.',
  },
];
---

<BaseLayout
  title="Before we dig the hole, we should ask the right question."
  description="An evidence-based look at the proposed 50-year regional landfill at Blakebrook Quarry: the proposal, the critique, the alternatives, and the numbers."
>
  <!-- Magazine-cover hero -->
  <section class="mx-auto max-w-5xl px-5 pt-16 sm:pt-24">
    <Eyebrow>A regional landfill at Blakebrook Quarry</Eyebrow>
    <h1
      class="mt-5 max-w-4xl font-display text-[2.75rem] font-semibold leading-[1.02] text-basalt sm:text-7xl"
    >
      Before we dig the hole, we should ask the right question.
    </h1>
    <div class="mt-8 max-w-2xl">
      <Standfirst>
        Lismore City Council is investigating Blakebrook Quarry as the site for
        a 50-year regional landfill serving up to seven Northern Rivers
        councils. The case for the site rests on three claims: that modern
        landfill engineering eliminates risk, that 60,000 tonnes per year is
        modest, and that opposition is &ldquo;hype.&rdquo; This site examines
        each of those claims, proposes alternative approaches, and asks whether
        a 50-year landfill commitment is the right answer to the waste problem
        at all.
      </Standfirst>
    </div>
  </section>

  <!-- CTA cards -->
  <section class="mx-auto mt-14 max-w-5xl px-5">
    <h2 class="sr-only">Explore the analysis</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {cards.map((c) => <CardLink {...c} />)}
    </div>
  </section>

  <!-- What the council has said -->
  <PullQuote cite="Mayor Steve Krieg, Lismore City Council, September 2025">
    No decision has been made to build a landfill at Blakebrook. At this point,
    we&rsquo;re simply investigating whether the site is suitable.
  </PullQuote>

  <!-- Editorial position -->
  <section class="mx-auto max-w-prose px-5">
    <Eyebrow>How we approach this</Eyebrow>
    <div class="prose-body mt-4">
      <p>
        This is an independent information resource, not a petition platform.
        The aim is that you leave better informed — not simply more angry.
        Where the council&rsquo;s reasoning is sound, we say so; where the
        public case is thin, we show why.
      </p>
      <p>We hold ourselves to a short set of rules:</p>
      <ul>
        <li>Every contested factual claim carries a source.</li>
        <li>
          We separate fact from opinion in plain voice — &ldquo;the council
          argues,&rdquo; &ldquo;the evidence suggests,&rdquo; &ldquo;in our
          view.&rdquo;
        </li>
        <li>
          We critique the process and the framing, not the integrity of any
          individual.
        </li>
        <li>
          We do not name private landowners or parcels as alternative sites.
        </li>
      </ul>
      <p>
        The full editorial standards and corrections policy are on the{' '}
        <a href="/about">about page</a>. {SITE.name} is published by{' '}
        <span class="font-mono text-sm">{SITE.author}</span>.
      </p>
    </div>
  </section>
</BaseLayout>
